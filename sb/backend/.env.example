# ─── SkillBarter Backend — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values.

# MongoDB connection string
# Local:  mongodb://localhost:27017/skillbarter
# Atlas:  mongodb+srv://username:password@cluster.mongodb.net/skillbarter
MONGO_URI=mongodb://localhost:27017/skillbarter

# JWT secret – use a long random string in production
JWT_SECRET=skillbarter_super_secret_change_this_in_production

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Python AI microservice URL (optional – fallback scoring used if down)
AI_SERVICE_URL=http://localhost:8000/recommend

# Server port
PORT=5000

# Environment
NODE_ENV=development
